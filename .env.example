PORT=4000
DATABASE_URL=postgres://user:password@localhost:5432/research_papers_db
UPLOAD_DIR=uploads
# Comma-separated origins, or * for reflect-any (dev only). Omit to allow any origin (dev).
CORS_ORIGIN=http://localhost:3000
# Max requests per IP per 15 minutes (skipped for / and /health; disabled in NODE_ENV=test).
RATE_LIMIT_MAX=300
KHALTI_SECRET_KEY=your_khalti_secret_key
KHALTI_PUBLIC_KEY=your_khalti_public_key
KHALTI_RETURN_URL=http://localhost:4000/payment/verify
